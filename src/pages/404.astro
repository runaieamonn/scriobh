---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <p class="text-6xl font-bold text-zinc-200 dark:text-zinc-800">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Page not found</h1>
    <p class="mt-2 text-zinc-500 dark:text-zinc-400">This page doesn't exist or has been moved.</p>
    <a href="/" class="mt-6 inline-block text-indigo-600 dark:text-indigo-400 font-medium hover:underline">
      Go home →
    </a>
  </div>
</Layout>
