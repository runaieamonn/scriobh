---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { slugGradient } from '../utils/gradient';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, date, excerpt, coverImage } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const gradient = slugGradient(post.slug);
---

<Layout title={`${title} — eamonn.org`} description={excerpt} ogImage={coverImage}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <!-- Cover image or gradient banner -->
    <div class="mb-8 rounded-2xl overflow-hidden aspect-video">
      {coverImage ? (
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${gradient}`} />
      )}
    </div>

    <header class="mb-10">
      <time
        datetime={date.toISOString()}
        class="text-sm font-medium text-zinc-400 dark:text-zinc-500 uppercase tracking-wide"
      >
        {formattedDate}
      </time>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-zinc-100 tracking-tight leading-tight">
        {title}
      </h1>
    </header>

    <div class="prose prose-zinc dark:prose-invert prose-headings:font-semibold prose-a:text-indigo-600 dark:prose-a:text-indigo-400 prose-a:no-underline hover:prose-a:underline prose-pre:rounded-xl prose-img:rounded-xl max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
        </svg>
        All posts
      </a>
    </div>
  </article>
</Layout>
